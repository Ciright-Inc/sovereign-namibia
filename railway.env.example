# Railway service variables — Sovereign Namibia

# Required (reference Postgres plugin)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Required — generate secure random values for production
ENCRYPTION_KEY=
SESSION_SECRET=
JWT_SECRET=

# Public URLs (set before first build)
NEXT_PUBLIC_ROOT_DOMAIN=sovereignnamibia.com
NEXT_PUBLIC_APP_URL=https://YOUR-SERVICE.up.railway.app

NODE_ENV=production

# Optional
SKIP_DB_MIGRATE=false
SKIP_DB_SEED=false
DB_MIGRATE_MAX_RETRIES=30
